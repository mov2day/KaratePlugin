{
  "name": "karate-test-generator",
  "displayName": "Karate API Test Generator",
  "description": "Professional Karate Test Generator & Maintenance with Multi-AI - Transform OpenAPI, Postman, Confluence, GraphQL, and Jira into automated tests",
  "version": "1.5.2",
  "publisher": "MuthuKumarKoodalingam",
  "license": "MIT",
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.108.0"
  },
  "pricing": "Free",
  "categories": [
    "Testing",
    "AI",
    "Programming Languages"
  ],
  "keywords": [
    "karate",
    "karate dsl",
    "karate api",
    "api testing",
    "api test generator",
    "openapi",
    "swagger",
    "openapi test generator",
    "rest api testing",
    "bdd",
    "qa automation",
    "contract testing",
    "test automation",
    "postman",
    "postman converter",
    "postman to karate",
    "postman to karate converter",
    "postman migration",
    "postman migration to karate",
    "AI Test Generator",
    "AI Test Automation",
    "AI Test Automation for API",
    "GitHub Copilot",
    "AI",
    "contract testing",
    "automated testing",
    "Karate DSL",
    "Gherkin",
    "Karate executor",
    "Karate test runner",
    "Karate test report",
    "Karate test coverage",
    "api bug hunter",
    "api fuzzing",
    "api security testing",
    "owasp api security",
    "openapi fuzz testing"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mov2day/KaratePlugin.git"
  },
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "karate-dsl.generateFromOpenAPI",
        "title": "Karate: Generate Tests from OpenAPI"
      },
      {
        "command": "karate-dsl.generateFromConfluence",
        "title": "Karate: Generate Tests from Confluence"
      },
      {
        "command": "karate-dsl.generateCombined",
        "title": "Karate: Generate Combined Tests"
      },
      {
        "command": "karate-dsl.openPanel",
        "title": "Karate: Open Test Generator"
      },
      {
        "command": "karate-dsl.generateFromExplorer",
        "title": "Karate: Open in Test Generator"
      },
      {
        "command": "karate-dsl.generateFromExplorerDirect",
        "title": "Karate: Generate Tests Now"
      },
      {
        "command": "karate-dsl.learnStyleFromExplorer",
        "title": "Karate: Open Style Learning"
      },
      {
        "command": "karate-dsl.learnStyleFromExplorerDirect",
        "title": "Karate: Learn Style Now"
      },
      {
        "command": "karate-dsl.migrateFeatureToV2",
        "title": "Karate: Migrate Feature to v2"
      },
      {
        "command": "karate-dsl.viewTrackedSpecs",
        "title": "Karate: View Tracked Specs"
      },
      {
        "command": "karate-dsl.checkSpecChanges",
        "title": "Karate: Check for Spec Changes"
      },
      {
        "command": "karate-dsl.compareOpenAPIVersions",
        "title": "Karate: Compare OpenAPI Versions"
      },
      {
        "command": "karate-dsl.showCoverageDashboard",
        "title": "Karate: Show Test Coverage Dashboard"
      },
      {
        "command": "karate-dsl.showCopilotActivity",
        "title": "Karate: Show Copilot Activity Log"
      },
      {
        "command": "karate-dsl.clearCopilotActivity",
        "title": "Karate: Clear Copilot Activity Log"
      },
      {
        "command": "karate-dsl.importPostmanCollection",
        "title": "Karate: Import Postman Collection"
      },
      {
        "command": "karate-dsl.selectCopilotModel",
        "title": "Karate: Select Copilot Model"
      },
      {
        "command": "karate-dsl.analyzeProjectHealth",
        "title": "Karate: Analyze Project Health"
      },
      {
        "command": "karate-dsl.runFeature",
        "title": "Karate: Run Feature"
      },
      {
        "command": "karate-dsl.runScenario",
        "title": "Karate: Run Scenario"
      },
      {
        "command": "karate-dsl.runFolder",
        "title": "Karate: Run All Tests in Folder"
      },
      {
        "command": "karate-dsl.runByTags",
        "title": "Karate: Run Tests by Tags"
      },
      {
        "command": "karate-dsl.showExecutionReport",
        "title": "Karate: Show Test Execution Report"
      },
      {
        "command": "karate-dsl.showTestHistory",
        "title": "Karate: Show Test History"
      },
      {
        "command": "karate-dsl.clearKarateCache",
        "title": "Karate: Clear JAR Cache"
      },
      {
        "command": "karate-dsl.copilotSuggest",
        "title": "Karate: AI Powered Suggestion"
      },
      {
        "command": "karate-dsl.startRecording",
        "title": "Karate: Start Recording Session"
      },
      {
        "command": "karate-dsl.stopRecording",
        "title": "Karate: Stop Recording & Synthesize"
      },
      {
        "command": "karate-dsl.importHar",
        "title": "Karate: Import HAR File"
      },
      {
        "command": "karate-dsl.synthesizeSession",
        "title": "Karate: Synthesize Session to Karate"
      },
      {
        "command": "karate-dsl.generateFromGraphQL",
        "title": "Karate: Generate Tests from GraphQL"
      },
      {
        "command": "karate-dsl.generateFromDirectory",
        "title": "Karate: Generate Tests from Directory"
      },
      {
        "command": "karate-dsl.generateFromJira",
        "title": "Karate: Generate Tests from Jira"
      },
      {
        "command": "karate-dsl.setClaudeApiKey",
        "title": "Karate: Set Claude API Key"
      },
      {
        "command": "karate-dsl.setGitHubToken",
        "title": "Karate: Set GitHub Token"
      },
      {
        "command": "karate-dsl.setZephyrToken",
        "title": "Karate: Set Zephyr Bearer Token"
      },
      {
        "command": "karate-dsl.showMcpConnectionInfo",
        "title": "Karate: Show MCP Connection Info"
      },
      {
        "command": "karate-dsl.showCIBridgeGuide",
        "title": "Karate: Show CI Bridge Guide"
      },
      {
        "command": "karate-dsl.huntApiBugs",
        "title": "Karate: Hunt API Bugs"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "karate-generator",
          "title": "Karate Test Generator",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "menus": {
      "explorer/context": [
        {
          "command": "karate-dsl.generateFromExplorerDirect",
          "when": "resourceExtname == .json || resourceExtname == .yaml || resourceExtname == .yml",
          "group": "karate@1"
        },
        {
          "command": "karate-dsl.generateFromExplorer",
          "when": "resourceExtname == .json || resourceExtname == .yaml || resourceExtname == .yml",
          "group": "karate@2"
        },
        {
          "command": "karate-dsl.learnStyleFromExplorerDirect",
          "when": "resourceExtname == .feature",
          "group": "karate@3"
        },
        {
          "command": "karate-dsl.learnStyleFromExplorer",
          "when": "resourceExtname == .feature",
          "group": "karate@4"
        },
        {
          "command": "karate-dsl.migrateFeatureToV2",
          "when": "resourceExtname == .feature",
          "group": "karate@5"
        },
        {
          "command": "karate-dsl.generateFromDirectory",
          "when": "explorerResourceIsFolder",
          "group": "karate@6"
        },
        {
          "command": "karate-dsl.generateFromGraphQL",
          "when": "resourceExtname == .graphql || resourceExtname == .gql",
          "group": "karate@7"
        }
      ],
      "editor/context": [
        {
          "command": "karate-dsl.generateFromExplorerDirect",
          "when": "resourceExtname == .json || resourceExtname == .yaml || resourceExtname == .yml",
          "group": "karate@1"
        },
        {
          "command": "karate-dsl.generateFromExplorer",
          "when": "resourceExtname == .json || resourceExtname == .yaml || resourceExtname == .yml",
          "group": "karate@2"
        },
        {
          "command": "karate-dsl.learnStyleFromExplorerDirect",
          "when": "resourceExtname == .feature",
          "group": "karate@3"
        },
        {
          "command": "karate-dsl.learnStyleFromExplorer",
          "when": "resourceExtname == .feature",
          "group": "karate@4"
        },
        {
          "command": "karate-dsl.migrateFeatureToV2",
          "when": "resourceExtname == .feature",
          "group": "karate@5"
        },
        {
          "command": "karate-dsl.runFeature",
          "when": "resourceExtname == .feature",
          "group": "karateExecution@1"
        },
        {
          "command": "karate-dsl.runScenario",
          "when": "editorTextFocus && resourceExtname == .feature",
          "group": "karateExecution@2"
        }
      ]
    },
    "views": {
      "karate-generator": [
        {
          "type": "webview",
          "id": "karateGenerator.mainView",
          "name": "Test Generator"
        }
      ]
    },
    "configuration": {
      "title": "Karate DSL Generator",
      "properties": {
        "karateDsl.outputPath": {
          "type": "string",
          "default": "src/test/karate",
          "description": "Default output path for generated Karate feature files"
        },
        "karateDsl.confluence.baseUrl": {
          "type": "string",
          "default": "",
          "description": "Confluence base URL (e.g., https://yourcompany.atlassian.net/wiki)"
        },
        "karateDsl.confluence.email": {
          "type": "string",
          "default": "",
          "description": "Confluence user email for authentication"
        },
        "karateDsl.confluence.authType": {
          "type": "string",
          "enum": [
            "basic",
            "bearer"
          ],
          "default": "basic",
          "description": "Authentication type: 'basic' for Confluence Cloud (email:token), 'bearer' for Data Center/Server PAT tokens",
          "enumDescriptions": [
            "Basic Auth (Cloud): Uses email:token encoded as Base64",
            "Bearer Token (Data Center/Server): Uses PAT token with Bearer scheme"
          ]
        },
        "karateDsl.testTemplate": {
          "type": "string",
          "enum": [
            "standard",
            "detailed",
            "minimal"
          ],
          "default": "standard",
          "description": "Test generation template style"
        },
        "karateDsl.useCopilot": {
          "type": "boolean",
          "default": false,
          "description": "Use GitHub Copilot to enhance generated tests (requires GitHub Copilot subscription)"
        },
        "karate.copilot.logging.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable transparent logging of all Copilot interactions (prompts and responses)"
        },
        "karate.copilot.logging.redactSensitiveData": {
          "type": "boolean",
          "default": true,
          "description": "Automatically redact sensitive data (API keys, tokens, passwords) from Copilot activity logs"
        },
        "karate.copilot.logging.showTokenUsage": {
          "type": "boolean",
          "default": true,
          "description": "Show token usage statistics for Copilot requests in the activity log"
        },
        "karateDsl.agentSkills.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Agent Skills support (requires VS Code 1.108+ and chat.useAgentSkills setting)"
        },
        "karateDsl.agentSkills.autoSuggest": {
          "type": "boolean",
          "default": true,
          "description": "Automatically suggest relevant Agent Skills based on context"
        },
        "karateDsl.agentSkills.showInStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show Agent Skills status in the status bar"
        },
        "karateDsl.copilot.model": {
          "type": "string",
          "default": "gpt-5-mini",
          "description": "Select the GitHub Copilot model to use for test generation",
          "enum": [
            "gpt-5-mini",
            "gpt-5.2-codex",
            "claude-sonnet-4.5",
            "claude-haiku-4.5",
            "claude-opus-4.5",
            "gpt-4o",
            "gpt-4",
            "gpt-3.5-turbo"
          ],
          "enumDescriptions": [
            "GPT-5 Mini (Fast & Efficient) - Recommended",
            "GPT-5.2 Codex (Optimized for Code Generation)",
            "Claude Sonnet 4.5 (Balanced, Best Coding Model)",
            "Claude Haiku 4.5 (Fast, Cost-Efficient)",
            "Claude Opus 4.5 (Maximum Intelligence, Flagship)",
            "GPT-4 Omni (Vision Support)",
            "GPT-4 (Legacy)",
            "GPT-3.5 Turbo (Fast)"
          ]
        },
        "karateDsl.generation.structuringStrategy": {
          "type": "string",
          "default": "domain",
          "description": "How to organize generated feature files: domain (group by API tag/path), flat (single file), method (group by HTTP method)",
          "enum": [
            "domain",
            "flat",
            "method"
          ],
          "enumDescriptions": [
            "Domain grouping — one feature file per API domain (e.g., orders.feature, payments.feature)",
            "Flat — all scenarios in a single feature file (classic behavior)",
            "Method grouping — one feature file per HTTP method (e.g., get.feature, post.feature)"
          ]
        },
        "karateDsl.generation.autoTag": {
          "type": "boolean",
          "default": true,
          "description": "Automatically tag generated scenarios with @positive, @negative, @edge, @boundary, and @domain tags"
        },
        "karateDsl.health.disabledRules": {
          "type": "array",
          "default": [],
          "description": "List of health check rules to disable"
        },
        "karateDsl.execution.defaultBuildTool": {
          "type": "string",
          "enum": [
            "cli",
            "maven",
            "gradle"
          ],
          "default": "cli",
          "description": "Default build tool to use for test execution"
        },
        "karateDsl.execution.parallelThreads": {
          "type": "number",
          "default": 1,
          "minimum": 1,
          "maximum": 16,
          "description": "Number of parallel threads for test execution"
        },
        "karateDsl.execution.historyLimit": {
          "type": "number",
          "default": 50,
          "minimum": 10,
          "maximum": 200,
          "description": "Number of test execution history entries to keep"
        },
        "karateDsl.execution.autoOpenReport": {
          "type": "boolean",
          "default": true,
          "description": "Automatically open execution report after running tests"
        },
        "karateDsl.execution.configPath": {
          "type": "string",
          "default": "",
          "description": "Custom path to karate-config.js or Java runner class (relative to workspace root)"
        },
        "karateDsl.execution.additionalClasspath": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional classpath entries for test execution (relative or absolute paths)"
        },
        "karateDsl.execution.jvmArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "Custom JVM arguments passed to every test run. Example: `[\"-Xmx512m\", \"-Dfile.encoding=UTF-8\"]`"
        },
        "karateDsl.execution.karateArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "Custom Karate CLI arguments appended to every test run. Example: `[\"--threads\", \"5\", \"--configdir\", \"src/test/resources\"]`"
        },
        "karateDsl.execution.jarPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Exact local Karate standalone JAR path. Leave blank to use the bundled Karate 1.5.0.RC3 JAR."
        },
        "karateDsl.execution.karateVersion": {
          "type": "string",
          "default": "",
          "markdownDescription": "Karate standalone JAR version to download and cache, e.g. `2.1.0`. Leave blank to use the bundled Karate 1.5.0.RC3 JAR."
        },
        "karateDsl.execution.systemProperties": {
          "type": "object",
          "default": {},
          "markdownDescription": "System properties passed as `-D` flags to every test run. Example: `{\"karate.env\": \"dev\", \"myapp.baseUrl\": \"http://localhost:8080\"}`",
          "additionalProperties": {
            "type": "string"
          }
        },
        "karateDsl.session.proxyPort": {
          "type": "number",
          "default": 8081,
          "minimum": 1024,
          "maximum": 65535,
          "description": "Port for session recording proxy server"
        },
        "karate.linter.enabledRules": {
          "type": "object",
          "default": {},
          "description": "Enable/Disable specific linter rules (e.g. \"K001\": false)",
          "additionalProperties": {
            "type": "boolean"
          }
        },
        "karateDsl.ai.provider": {
          "type": "string",
          "enum": ["auto", "copilot", "claude-api", "ollama"],
          "default": "auto",
          "description": "Active AI provider: auto (try copilot first), copilot, claude-api, or ollama",
          "enumDescriptions": [
            "Auto: Try Copilot first, then Claude API, then Ollama",
            "GitHub Copilot (requires Copilot subscription)",
            "Claude API (requires Anthropic API key)",
            "Ollama (local inference, requires Ollama running)"
          ]
        },
        "karateDsl.ai.claudeApiModel": {
          "type": "string",
          "default": "claude-sonnet-4-6",
          "description": "Model to use for Claude API calls"
        },
        "karateDsl.ai.ollamaEndpoint": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Ollama inference server URL"
        },
        "karateDsl.ai.ollamaModel": {
          "type": "string",
          "default": "llama3",
          "description": "Model name to use with Ollama"
        },
        "karateDsl.ciRepair.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable CI failure ingestion and AI-assisted test repair"
        },
        "karateDsl.ciRepair.mode": {
          "type": "string",
          "enum": [
            "pull",
            "webhook",
            "both"
          ],
          "default": "pull",
          "description": "CI failure ingestion mode: pull GitHub Actions API, webhook listener, or both"
        },
        "karateDsl.ciRepair.github.owner": {
          "type": "string",
          "default": "",
          "description": "GitHub repository owner for CI pull mode"
        },
        "karateDsl.ciRepair.github.repo": {
          "type": "string",
          "default": "",
          "description": "GitHub repository name for CI pull mode"
        },
        "karateDsl.ciRepair.github.workflow": {
          "type": "string",
          "default": "",
          "description": "Optional workflow file name or workflow ID filter for CI pull mode"
        },
        "karateDsl.ciRepair.github.branch": {
          "type": "string",
          "default": "main",
          "description": "Branch filter used for CI pull mode"
        },
        "karateDsl.ciRepair.github.pollIntervalSec": {
          "type": "number",
          "default": 90,
          "minimum": 30,
          "maximum": 3600,
          "description": "Polling interval in seconds for CI pull mode"
        },
        "karateDsl.ciRepair.github.artifactNamePattern": {
          "type": "string",
          "default": "karate|junit|test|report",
          "description": "Regex pattern for selecting GitHub Actions artifacts to inspect"
        },
        "karateDsl.ciRepair.github.lookbackMinutes": {
          "type": "number",
          "default": 120,
          "minimum": 5,
          "maximum": 10080,
          "description": "How far back to search failed GitHub Actions runs"
        },
        "karateDsl.ciRepair.webhookPort": {
          "type": "number",
          "default": 47392,
          "minimum": 1024,
          "maximum": 65535,
          "description": "Local port for CI failure webhook"
        },
        "karateDsl.ciRepair.autoApply": {
          "type": "boolean",
          "default": false,
          "description": "Automatically apply AI repairs without showing diff first"
        },
        "karateDsl.ciRepair.backupBeforeRepair": {
          "type": "boolean",
          "default": true,
          "description": "Create backup of feature file before applying AI repair"
        },
        "karateDsl.flakiness.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable flakiness detection and scoring"
        },
        "karateDsl.flakiness.windowSize": {
          "type": "number",
          "default": 20,
          "minimum": 5,
          "maximum": 100,
          "description": "Number of historical runs to analyse for flakiness"
        },
        "karateDsl.flakiness.threshold": {
          "type": "number",
          "default": 0.15,
          "minimum": 0,
          "maximum": 1,
          "description": "Flakiness score threshold (0.0–1.0). Scenarios above this are flagged as flaky"
        },
        "karateDsl.flakiness.thresholds": {
          "type": "object",
          "default": {
            "watch": 0.2,
            "flaky": 0.5,
            "broken": 0.8
          },
          "description": "Tier thresholds for flakiness labels (stable/watch/flaky/broken)",
          "properties": {
            "watch": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "flaky": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "broken": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        },
        "karateDsl.flakiness.showInStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show flaky test count in status bar"
        },
        "karateDsl.generation.smartTestData": {
          "type": "boolean",
          "default": true,
          "description": "Use realistic, field-aware test values instead of generic placeholders"
        },
        "karateDsl.generation.scenarioOutlineThreshold": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 10,
          "description": "Minimum required fields to trigger Scenario Outline auto-generation"
        },
        "karateDsl.generation.sharedStylePath": {
          "type": "string",
          "default": "",
          "description": "Path to workspace-shared .karate-style.json file (relative or absolute)"
        },
        "karateDsl.mcp.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable extension-managed Karate MCP host server"
        },
        "karateDsl.mcp.host": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "Host interface for Karate MCP server"
        },
        "karateDsl.mcp.port": {
          "type": "number",
          "default": 47393,
          "minimum": 1024,
          "maximum": 65535,
          "description": "Port for Karate MCP server"
        },
        "karateDsl.mcp.tokenAuthEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Require Bearer token authentication for Karate MCP endpoints"
        },
        "karateDsl.jira.baseUrl": {
          "type": "string",
          "default": "",
          "description": "Jira instance base URL (e.g., https://yourcompany.atlassian.net)"
        },
        "karateDsl.jira.email": {
          "type": "string",
          "default": "",
          "description": "Jira account email for Cloud authentication"
        },
        "karateDsl.jira.authType": {
          "type": "string",
          "enum": ["basic", "bearer"],
          "default": "basic",
          "description": "Jira authentication type: basic (Cloud email:token) or bearer (Data Center PAT)",
          "enumDescriptions": [
            "Basic Auth (Cloud): Uses email:token encoded as Base64",
            "Bearer Token (Data Center/Server): Uses PAT token with Bearer scheme"
          ]
        },
        "karateDsl.zephyr.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Push tagged Karate scenario results to Zephyr Scale Cloud after test runs"
        },
        "karateDsl.zephyr.baseUrl": {
          "type": "string",
          "default": "https://eu.api.zephyrscale.smartbear.com/v2",
          "description": "Zephyr Scale Cloud API base URL"
        },
        "karateDsl.zephyr.projectKey": {
          "type": "string",
          "default": "",
          "description": "Jira project key for Zephyr Scale executions, e.g. PROJ"
        },
        "karateDsl.zephyr.cycleName": {
          "type": "string",
          "default": "Karate Regression",
