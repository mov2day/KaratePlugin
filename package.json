{
  "name": "karate-test-generator",
  "displayName": "Karate API Test Generator",
  "description": "Professional Karate Test Generator & Maintenance with AI - Transform OpenAPI, Postman, and Confluence into automated tests with GitHub Copilot",
  "version": "1.3.1",
  "publisher": "MuthuKumarKoodalingam",
  "license": "MIT",
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.108.0"
  },
  "pricing": "Free",
  "categories": [
    "Testing",
    "AI",
    "Programming Languages"
  ],
  "keywords": [
    "karate",
    "karate dsl",
    "karate api",
    "api testing",
    "api test generator",
    "openapi",
    "swagger",
    "openapi test generator",
    "rest api testing",
    "bdd",
    "qa automation",
    "contract testing",
    "test automation",
    "postman",
    "postman converter",
    "postman to karate",
    "postman to karate converter",
    "postman migration",
    "postman migration to karate",
    "AI Test Generator",
    "AI Test Automation",
    "AI Test Automation for API",
    "GitHub Copilot",
    "AI",
    "contract testing",
    "automated testing",
    "Karate DSL",
    "Gherkin"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mov2day/KaratePlugin.git"
  },
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "karate-dsl.generateFromOpenAPI",
        "title": "Karate: Generate Tests from OpenAPI"
      },
      {
        "command": "karate-dsl.generateFromConfluence",
        "title": "Karate: Generate Tests from Confluence"
      },
      {
        "command": "karate-dsl.generateCombined",
        "title": "Karate: Generate Combined Tests"
      },
      {
        "command": "karate-dsl.openPanel",
        "title": "Karate: Open Test Generator"
      },
      {
        "command": "karate-dsl.generateFromExplorer",
        "title": "Karate: Open in Test Generator"
      },
      {
        "command": "karate-dsl.generateFromExplorerDirect",
        "title": "Karate: Generate Tests Now"
      },
      {
        "command": "karate-dsl.learnStyleFromExplorer",
        "title": "Karate: Open Style Learning"
      },
      {
        "command": "karate-dsl.learnStyleFromExplorerDirect",
        "title": "Karate: Learn Style Now"
      },
      {
        "command": "karate-dsl.viewTrackedSpecs",
        "title": "Karate: View Tracked Specs"
      },
      {
        "command": "karate-dsl.checkSpecChanges",
        "title": "Karate: Check for Spec Changes"
      },
      {
        "command": "karate-dsl.compareOpenAPIVersions",
        "title": "Karate: Compare OpenAPI Versions"
      },
      {
        "command": "karate-dsl.showCoverageDashboard",
        "title": "Karate: Show Test Coverage Dashboard"
      },
      {
        "command": "karate-dsl.showCopilotActivity",
        "title": "Karate: Show Copilot Activity Log"
      },
      {
        "command": "karate-dsl.clearCopilotActivity",
        "title": "Karate: Clear Copilot Activity Log"
      },
      {
        "command": "karate-dsl.importPostmanCollection",
        "title": "Karate: Import Postman Collection"
      },
      {
        "command": "karate-dsl.selectCopilotModel",
        "title": "Karate: Select Copilot Model"
      },
      {
        "command": "karate-dsl.analyzeProjectHealth",
        "title": "Karate: Analyze Project Health"
      },
      {
        "command": "karate-dsl.runFeature",
        "title": "Karate: Run Feature"
      },
      {
        "command": "karate-dsl.runScenario",
        "title": "Karate: Run Scenario"
      },
      {
        "command": "karate-dsl.runFolder",
        "title": "Karate: Run All Tests in Folder"
      },
      {
        "command": "karate-dsl.runByTags",
        "title": "Karate: Run Tests by Tags"
      },
      {
        "command": "karate-dsl.showExecutionReport",
        "title": "Karate: Show Test Execution Report"
      },
      {
        "command": "karate-dsl.showTestHistory",
        "title": "Karate: Show Test History"
      },
      {
        "command": "karate-dsl.clearKarateCache",
        "title": "Karate: Clear JAR Cache"
      },
      {
        "command": "karate-dsl.copilotSuggest",
        "title": "Karate: AI Powered Suggestion"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "karate-generator",
          "title": "Karate Test Generator",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "menus": {
      "explorer/context": [
        {
          "command": "karate-dsl.generateFromExplorerDirect",
          "when": "resourceExtname == .json || resourceExtname == .yaml || resourceExtname == .yml",
          "group": "karate@1"
        },
        {
          "command": "karate-dsl.generateFromExplorer",
          "when": "resourceExtname == .json || resourceExtname == .yaml || resourceExtname == .yml",
          "group": "karate@2"
        },
        {
          "command": "karate-dsl.learnStyleFromExplorerDirect",
          "when": "resourceExtname == .feature",
          "group": "karate@3"
        },
        {
          "command": "karate-dsl.learnStyleFromExplorer",
          "when": "resourceExtname == .feature",
          "group": "karate@4"
        }
      ],
      "editor/context": [
        {
          "command": "karate-dsl.generateFromExplorerDirect",
          "when": "resourceExtname == .json || resourceExtname == .yaml || resourceExtname == .yml",
          "group": "karate@1"
        },
        {
          "command": "karate-dsl.generateFromExplorer",
          "when": "resourceExtname == .json || resourceExtname == .yaml || resourceExtname == .yml",
          "group": "karate@2"
        },
        {
          "command": "karate-dsl.learnStyleFromExplorerDirect",
          "when": "resourceExtname == .feature",
          "group": "karate@3"
        },
        {
          "command": "karate-dsl.learnStyleFromExplorer",
          "when": "resourceExtname == .feature",
          "group": "karate@4"
        },
        {
          "command": "karate-dsl.runFeature",
          "when": "resourceExtname == .feature",
          "group": "karateExecution@1"
        },
        {
          "command": "karate-dsl.runScenario",
          "when": "editorTextFocus && resourceExtname == .feature",
          "group": "karateExecution@2"
        }
      ]
    },
    "views": {
      "karate-generator": [
        {
          "type": "webview",
          "id": "karateGenerator.mainView",
          "name": "Test Generator"
        }
      ]
    },
    "configuration": {
      "title": "Karate DSL Generator",
      "properties": {
        "karateDsl.outputPath": {
          "type": "string",
          "default": "src/test/karate",
          "description": "Default output path for generated Karate feature files"
        },
        "karateDsl.confluence.baseUrl": {
          "type": "string",
          "default": "",
          "description": "Confluence base URL (e.g., https://yourcompany.atlassian.net/wiki)"
        },
        "karateDsl.confluence.email": {
          "type": "string",
          "default": "",
          "description": "Confluence user email for authentication"
        },
        "karateDsl.confluence.authType": {
          "type": "string",
          "enum": [
            "basic",
            "bearer"
          ],
          "default": "basic",
          "description": "Authentication type: 'basic' for Confluence Cloud (email:token), 'bearer' for Data Center/Server PAT tokens",
          "enumDescriptions": [
            "Basic Auth (Cloud): Uses email:token encoded as Base64",
            "Bearer Token (Data Center/Server): Uses PAT token with Bearer scheme"
          ]
        },
        "karateDsl.testTemplate": {
          "type": "string",
          "enum": [
            "standard",
            "detailed",
            "minimal"
          ],
          "default": "standard",
          "description": "Test generation template style"
        },
        "karateDsl.useCopilot": {
          "type": "boolean",
          "default": false,
          "description": "Use GitHub Copilot to enhance generated tests (requires GitHub Copilot subscription)"
        },
        "karate.copilot.logging.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable transparent logging of all Copilot interactions (prompts and responses)"
        },
        "karate.copilot.logging.redactSensitiveData": {
          "type": "boolean",
          "default": true,
          "description": "Automatically redact sensitive data (API keys, tokens, passwords) from Copilot activity logs"
        },
        "karate.copilot.logging.showTokenUsage": {
          "type": "boolean",
          "default": true,
          "description": "Show token usage statistics for Copilot requests in the activity log"
        },
        "karateDsl.agentSkills.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Agent Skills support (requires VS Code 1.108+ and chat.useAgentSkills setting)"
        },
        "karateDsl.agentSkills.autoSuggest": {
          "type": "boolean",
          "default": true,
          "description": "Automatically suggest relevant Agent Skills based on context"
        },
        "karateDsl.agentSkills.showInStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show Agent Skills status in the status bar"
        },
        "karateDsl.copilot.model": {
          "type": "string",
          "default": "gpt-5-mini",
          "description": "Select the GitHub Copilot model to use for test generation",
          "enum": [
            "gpt-5-mini",
            "gpt-5.2-codex",
            "claude-sonnet-4.5",
            "claude-haiku-4.5",
            "claude-opus-4.5",
            "gpt-4o",
            "gpt-4",
            "gpt-3.5-turbo"
          ],
          "enumDescriptions": [
            "GPT-5 Mini (Fast & Efficient) - Recommended",
            "GPT-5.2 Codex (Optimized for Code Generation)",
            "Claude Sonnet 4.5 (Balanced, Best Coding Model)",
            "Claude Haiku 4.5 (Fast, Cost-Efficient)",
            "Claude Opus 4.5 (Maximum Intelligence, Flagship)",
            "GPT-4 Omni (Vision Support)",
            "GPT-4 (Legacy)",
            "GPT-3.5 Turbo (Fast)"
          ]
        },
        "karateDsl.health.disabledRules": {
          "type": "array",
          "default": [],
          "description": "List of health check rules to disable"
        },
        "karateDsl.execution.defaultBuildTool": {
          "type": "string",
          "enum": [
            "cli",
            "maven",
            "gradle"
          ],
          "default": "cli",
          "description": "Default build tool to use for test execution"
        },
        "karateDsl.execution.parallelThreads": {
          "type": "number",
          "default": 1,
          "minimum": 1,
          "maximum": 16,
          "description": "Number of parallel threads for test execution"
        },
        "karateDsl.execution.historyLimit": {
          "type": "number",
          "default": 50,
          "minimum": 10,
          "maximum": 200,
          "description": "Number of test execution history entries to keep"
        },
        "karateDsl.execution.autoOpenReport": {
          "type": "boolean",
          "default": true,
          "description": "Automatically open execution report after running tests"
        },
        "karate.linter.enabledRules": {
          "type": "object",
          "default": {},
          "description": "Enable/Disable specific linter rules (e.g. \"K001\": false)",
          "additionalProperties": {
            "type": "boolean"
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.x",
    "@types/vscode": "^1.108.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vscode/test-electron": "^2.3.8",
    "@vscode/vsce": "^2.22.0",
    "eslint": "^8.56.0",
    "mocha": "^10.2.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "axios": "^1.6.2",
    "js-yaml": "^4.1.0",
    "swagger-parser": "^10.0.3"
  }
}