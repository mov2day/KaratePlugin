{
  "name": "karate-test-generator",
  "displayName": "Karate Test Generator",
  "description": "AI-Powered Test Generation & Maintenance for Karate DSL - Generate tests from OpenAPI specs with GitHub Copilot integration",
  "version": "1.2.0",
  "publisher": "MuthuKumarKoodalingam",
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Testing",
    "Other"
  ],
  "keywords": [
    "karate",
    "api testing",
    "openapi",
    "swagger",
    "confluence",
    "test generation",
    "AI Test Generation",
    "Copilot",
    "AI Test Automation",
    "Test Automation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mov2day/KaratePlugin.git"
  },
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "karate-dsl.generateFromOpenAPI",
        "title": "Karate: Generate Tests from OpenAPI"
      },
      {
        "command": "karate-dsl.generateFromConfluence",
        "title": "Karate: Generate Tests from Confluence"
      },
      {
        "command": "karate-dsl.generateCombined",
        "title": "Karate: Generate Combined Tests"
      },
      {
        "command": "karate-dsl.openPanel",
        "title": "Karate: Open Test Generator"
      },
      {
        "command": "karate-dsl.generateFromExplorer",
        "title": "Karate: Open in Test Generator"
      },
      {
        "command": "karate-dsl.generateFromExplorerDirect",
        "title": "Karate: Generate Tests Now"
      },
      {
        "command": "karate-dsl.learnStyleFromExplorer",
        "title": "Karate: Open Style Learning"
      },
      {
        "command": "karate-dsl.learnStyleFromExplorerDirect",
        "title": "Karate: Learn Style Now"
      },
      {
        "command": "karate-dsl.viewTrackedSpecs",
        "title": "Karate: View Tracked Specs"
      },
      {
        "command": "karate-dsl.checkSpecChanges",
        "title": "Karate: Check for Spec Changes"
      },
      {
        "command": "karate-dsl.compareOpenAPIVersions",
        "title": "Karate: Compare OpenAPI Versions"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "karate-generator",
          "title": "Karate Test Generator",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "menus": {
      "explorer/context": [
        {
          "command": "karate-dsl.generateFromExplorerDirect",
          "when": "resourceExtname == .json || resourceExtname == .yaml || resourceExtname == .yml",
          "group": "karate@1"
        },
        {
          "command": "karate-dsl.generateFromExplorer",
          "when": "resourceExtname == .json || resourceExtname == .yaml || resourceExtname == .yml",
          "group": "karate@2"
        },
        {
          "command": "karate-dsl.learnStyleFromExplorerDirect",
          "when": "resourceExtname == .feature",
          "group": "karate@3"
        },
        {
          "command": "karate-dsl.learnStyleFromExplorer",
          "when": "resourceExtname == .feature",
          "group": "karate@4"
        }
      ],
      "editor/context": [
        {
          "command": "karate-dsl.generateFromExplorerDirect",
          "when": "resourceExtname == .json || resourceExtname == .yaml || resourceExtname == .yml",
          "group": "karate@1"
        },
        {
          "command": "karate-dsl.generateFromExplorer",
          "when": "resourceExtname == .json || resourceExtname == .yaml || resourceExtname == .yml",
          "group": "karate@2"
        },
        {
          "command": "karate-dsl.learnStyleFromExplorerDirect",
          "when": "resourceExtname == .feature",
          "group": "karate@3"
        },
        {
          "command": "karate-dsl.learnStyleFromExplorer",
          "when": "resourceExtname == .feature",
          "group": "karate@4"
        }
      ]
    },
    "views": {
      "karate-generator": [
        {
          "type": "webview",
          "id": "karateGenerator.mainView",
          "name": "Test Generator"
        }
      ]
    },
    "configuration": {
      "title": "Karate DSL Generator",
      "properties": {
        "karateDsl.outputPath": {
          "type": "string",
          "default": "src/test/karate",
          "description": "Default output path for generated Karate feature files"
        },
        "karateDsl.confluence.baseUrl": {
          "type": "string",
          "default": "",
          "description": "Confluence base URL (e.g., https://yourcompany.atlassian.net/wiki)"
        },
        "karateDsl.confluence.email": {
          "type": "string",
          "default": "",
          "description": "Confluence user email for authentication"
        },
        "karateDsl.testTemplate": {
          "type": "string",
          "enum": [
            "standard",
            "detailed",
            "minimal"
          ],
          "default": "standard",
          "description": "Test generation template style"
        },
        "karateDsl.useCopilot": {
          "type": "boolean",
          "default": false,
          "description": "Use GitHub Copilot to enhance generated tests (requires GitHub Copilot subscription)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vscode/test-electron": "^2.3.8",
    "@vscode/vsce": "^2.22.0",
    "eslint": "^8.56.0",
    "mocha": "^10.2.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "axios": "^1.6.2",
    "js-yaml": "^4.1.0",
    "swagger-parser": "^10.0.3"
  }
}